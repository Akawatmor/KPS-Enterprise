# ─────────────────────────────────────────────────────────────────────────────
# TodoApp — Environment Variables
# Copy this file to .env and fill in the real values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Backend server port (default 8080)
SERVER_PORT=8080

# Storage backend: sqlite | postgres | memory
DATA_BACKEND=sqlite

# SQLite database path (used when DATA_BACKEND=sqlite)
SQLITE_PATH=/var/lib/todoapp/todoapp.db

# PostgreSQL DSN (used when DATA_BACKEND=postgres)
# POSTGRES_DSN=postgres://user:password@host:5432/todoapp?sslmode=disable

# CORS allowed origin for the frontend
ALLOWED_ORIGIN=http://localhost:3000

# Token lifetimes (minutes)
AUTH_ACCESS_TOKEN_MINUTES=15
AUTH_REFRESH_TOKEN_MINUTES=10080

# GitHub OAuth credentials (optional — mock provider used if empty)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Background job intervals (seconds)
NAGGER_TICK_SECONDS=30

# ── Frontend ─────────────────────────────────────────────────────────────────
# Base URL for the backend API (used by Next.js server-side and browser)
# Leave empty to use relative /api paths (recommended behind a reverse proxy)
NEXT_PUBLIC_API_BASE_URL=
