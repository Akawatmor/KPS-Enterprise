apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: todoapp

resources:
  - namespace.yaml
  - configmap.yaml
  - postgres-pv.yaml
  - postgres-pvc.yaml
  - postgres-statefulset.yaml
  - core-deployment.yaml
  - core-service.yaml
  - web-deployment.yaml
  - web-service.yaml
  - ingress.yaml
