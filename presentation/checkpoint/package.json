{
  "name": "kps-enterprise-checkpoint",
  "version": "1.0.0",
  "description": "KPS-Enterprise Phase 1 Checkpoint Presentation",
  "scripts": {
    "build:pdf": "npx @marp-team/marp-cli slides.md -o slides.pdf --allow-local-files",
    "build:pptx": "npx @marp-team/marp-cli slides.md -o slides.pptx --allow-local-files",
    "build:html": "npx @marp-team/marp-cli slides.md -o slides.html --allow-local-files",
    "build:all": "npm run build:pdf && npm run build:pptx && npm run build:html",
    "preview": "npx @marp-team/marp-cli slides.md --preview"
  },
  "keywords": ["devops", "kubernetes", "ci-cd", "presentation"],
  "author": "KPS-Enterprise Team",
  "license": "MIT",
  "devDependencies": {
    "@marp-team/marp-cli": "^4.3.1"
  }
}
